# Copy to deploy/.env.prod on the VM and set real values.
# Non-secret defaults are provided; replace placeholders before launch.

POSTGRES_DB=crime_data
POSTGRES_USER=crime_app
POSTGRES_PASSWORD=change-me-strong-password

# Include Vercel production URL and local dev URLs as needed.
CORS_ORIGINS=https://your-project.vercel.app,http://localhost:5173,http://localhost:3000

# Keep CPU for Azure Student VM baseline.
PRED_DEVICE=cpu

# Runtime paths inside the backend container.
PRED_MODELS_DIR=/app/models
PRED_DATA_FALLBACK_CSV=/app/data/Chicago-Data/Crime/crime_1_day_pivot.csv

# Optional image tag for controlled rollback.
BACKEND_IMAGE=community-heatmaps-backend:latest
